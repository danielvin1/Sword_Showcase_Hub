{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "westeurope"
    },
    "environmentName": {
      "value": "prod"
    },
    "projectName": {
      "value": "sword-showcase"
    },
    "appServicePlanSkuName": {
      "value": "B1"
    },
    "appServicePlanCapacity": {
      "value": 1
    },
    "mysqlAdminUsername": {
      "value": "azureuser"
    },
    "mysqlVersion": {
      "value": "8.0.35"
    },
    "phpVersion": {
      "value": "8.3"
    },
    "keyVaultEnablePurgeProtection": {
      "value": false
    },
    "keyVaultEnableSoftDelete": {
      "value": true
    }
  }
}
